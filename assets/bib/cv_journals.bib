@article{patterson2022CategoricalData,
	title = {Categorical Data Structures for Technical Computing},
	volume = {Volume 4 (2022)},
	issn = {2631-4444},
	url = {https://compositionality.episciences.org/13519},
	doi = {10.32408/compositionality-4-5},
	abstract = {Many mathematical objects can be represented as functors from finitely-presented categories \${\textbackslash}mathsf\{C\}\$ to \${\textbackslash}mathsf\{Set\}\$. For instance, graphs are functors to \${\textbackslash}mathsf\{Set\}\$ from the category with two parallel arrows. Such functors are known informally as \${\textbackslash}mathsf\{C\}\$-sets. In this paper, we describe and implement an extension of \${\textbackslash}mathsf\{C\}\$-sets having data attributes with fixed types, such as graphs with labeled vertices or real-valued edge weights. We call such structures "acsets," short for "attributed \${\textbackslash}mathsf\{C\}\$-sets." Derived from previous work on algebraic databases, acsets are a joint generalization of graphs and data frames. They also encompass more elaborate graph-like objects such as wiring diagrams and Petri nets with rate constants. We develop the mathematical theory of acsets and then describe a generic implementation in the Julia programming language, which uses advanced language features to achieve performance comparable with specialized data structures.},
	journaltitle = {Compositionality},
	publisher = {Episciences.org},
	author = {Patterson, Evan and Lynch, Owen and Fairbanks, James},
	urldate = {2025-05-21},
	date = {2022-12-28},
	keywords = {Mathematics - Category Theory, Computer Science - Logic in Computer Science, cv-journal, Computer Science - Databases},
	file = {Full Text PDF:/Users/fairbanksj/Zotero/storage/59Z5GT3R/Patterson et al. - 2022 - Categorical Data Structures for Technical Computin.pdf:application/pdf},
}

